<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>

    <record id="base_localizacion_clientes.product_category_list_view_inherit" model="ir.ui.view">
        <field name="name">product.category.list.view.inherit</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </xpath>
        </field>
    </record>


    <!-- Acciones de categorias de productos -->
    <record id="base_localizacion_clientes.product_pos_category_action" model="ir.actions.act_window">
        <field name="name">Categorias de productos PTV</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pos.category</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{"search_default_company_category":1}</field>
        <field name="domain">['|',('company_id', '=', allowed_company_ids[0]),('company_id', '=', False)]</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to define a new product.
            </p><p>
                You must define a product for everything you sell, whether it's a physical product, a consumable or a service you offer to customers.
            </p><p>
                The product form contains information to simplify the sale process: price, notes in the quotation, accounting data, procurement methods, etc.
            </p>
        </field>
    </record>

        <!-- Formulario de categorias de productos -->
        <record id="base_localizacion_clientes.product_pos_category_form_view" model="ir.ui.view">
            <field name="name">base.localizacion.clientes.product.pos.category.form.view</field>
            <field name="model">pos.category</field>
            <field name="inherit_id" ref="point_of_sale.product_pos_category_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='sequence']" position="after">
                    <field name="company_id" class="oe_inline"/>
                </xpath>
            </field>
        </record>

        <!-- Formulario de categorias de productos -->
        <record id="base_localizacion_clientes.product_pos_category_tree_view" model="ir.ui.view">
            <field name="name">base.localizacion.clientes.product.pos.category.tree.view</field>
            <field name="model">pos.category</field>
            <field name="inherit_id" ref="point_of_sale.product_pos_category_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='display_name']" position="after">
                    <field name="company_id" class="oe_inline"/>
                </xpath>
            </field>
        </record>


        <record id="point_of_sale.product_pos_category_action" model="ir.actions.act_window">
        <field name="name">Categorias de productos PTV</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pos.category</field>
        <field name="view_mode">tree,form</field>
        <!-- <field name="view_type">form</field> -->
        <!-- <field name="view_id" ref="product.product_category_action_form"/> -->
        <field name="context">{"search_default_company_category":1}</field>
        <field name="domain">['|',('company_id', '=', allowed_company_ids[0]),('company_id', '=', False)]</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to define a new product.
            </p><p>
                You must define a product for everything you sell, whether it's a physical product, a consumable or a service you offer to customers.
            </p><p>
                The product form contains information to simplify the sale process: price, notes in the quotation, accounting data, procurement methods, etc.
            </p>
        </field>
        </record>        

  </data>
</odoo>