<odoo>
    <record id="view_repair_order_tree_inherit_amount_fields" model="ir.ui.view">
        <field name="name">repair.order.tree.inherit.amount.fields</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="amount_untaxed" sum="Total Untaxed" optional="show"/>
                <field name="amount_total" sum="Total" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
