<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_purchase_lines_wizard_form" model="ir.ui.view">
        <field name="name">import.purchase.lines.wizard.form</field>
        <field name="model">import.purchase.lines.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Purchase Order Lines">
                <group>
                    <field name="purchase_order_id" invisible="1"/>
                    <field name="filename" invisible="1"/>
                    <field name="file" filename="filename"/>
                </group>
                <group>
                    <button name="action_download_template" 
                            string="Download Template" 
                            type="object" 
                            class="oe_link"
                            icon="fa-download"/>
                </group>
                <footer>
                    <button name="action_import_lines" 
                            string="Import Lines" 
                            type="object" 
                            class="btn-primary"/>
                    <button name="action_cancel" 
                            string="Cancel" 
                            type="object" 
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_purchase_lines_wizard" model="ir.actions.server">
        <field name="name">Importar líneas PO</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_open_import_lines_wizard()</field>
    </record>
</odoo>
