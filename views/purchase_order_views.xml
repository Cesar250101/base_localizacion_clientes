<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_import" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.import</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='button_confirm']" position="before">
                <button name="action_open_import_lines_wizard" 
                        string="Import Lines from Excel" 
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible': [('state', 'not in', ['draft', 'sent'])]}"/>
            </xpath>
        </field>
    </record>
</odoo>
