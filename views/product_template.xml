<odoo>
  <data>        
        <record id="base_localizacion_clientes.product_template_form_view" model="ir.ui.view">
            <field name="name">base.localizacion.clientes.product.template.form.view</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="attributes">
                    <attribute name="domain">['|',('company_id', '=', allowed_company_ids[0]),('company_id', '=', False)]</attribute>
                </xpath>
            </field>
        </record>
  </data>
</odoo>        